GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth 로그인 (GitHub App Settings > OAuth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 접근 허용할 GitHub 로그인명 (콤마 구분, 예: okdoittttt,teammate)
ALLOWED_GITHUB_USERS=
# JWT 서명 키 (임의의 긴 랜덤 문자열)
JWT_SECRET=

# Database
DATABASE_URL=postgresql+asyncpg://almagest:almagest@db:5432/almagest_reviewer

# AI/LLM Configuration
LLM_PROVIDER=anthropic  # Options: anthropic, google, ollama
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (로컬 LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2


ENV=development
